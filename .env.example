# Database — CHANGE PASSWORD IN PRODUCTION!
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Frontend (only this port is exposed externally)
FRONTEND_PORT=3080

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://demo.triggers.online

# Auth for write endpoints (POST/DELETE). Leave empty to disable auth.
AUTH_USER=admin
AUTH_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
JWT_SECRET=CHANGE_ME_USE_RANDOM_STRING
